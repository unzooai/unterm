<script is:inline>
  // Install section: tab toggle + click-to-copy.
  //
  // is:inline so the markup ships even when JavaScript is disabled — the
  // first tab's <pre> is visible by default and users can still copy with
  // their own select/cmd+c. The script just upgrades the experience.
  (function () {
    const tabs = document.querySelectorAll(".install-tab");
    const panes = document.querySelectorAll(".install-pane");
    function activate(name) {
      tabs.forEach((t) => {
        const on = t.dataset.tab === name;
        t.classList.toggle("text-zinc-100", on);
        t.classList.toggle("bg-zinc-800/60", on);
        t.classList.toggle("text-zinc-400", !on);
      });
      panes.forEach((p) => {
        p.classList.toggle("hidden", p.dataset.pane !== name);
      });
    }
    tabs.forEach((t) => t.addEventListener("click", () => activate(t.dataset.tab)));

    // Click anywhere on the <pre> command block to copy. Keeps a tiny inline
    // toast so the user knows the copy fired without us having to render a
    // separate Copy button.
    const flashCopied = (el) => {
      const original = el.dataset.original ?? el.textContent;
      el.dataset.original = original;
      el.textContent = "✓ copied";
      setTimeout(() => { el.textContent = original; }, 1100);
    };
    document.querySelectorAll(".install-pane pre").forEach((pre) => {
      pre.style.cursor = "copy";
      pre.title = "click to copy";
      pre.addEventListener("click", async () => {
        const text = pre.textContent.trim();
        try {
          await navigator.clipboard.writeText(text);
          const code = pre.querySelector("code") ?? pre;
          flashCopied(code);
        } catch (_) {
          // navigator.clipboard requires HTTPS or localhost; fall back to
          // a hidden textarea + execCommand on legacy contexts.
          const ta = document.createElement("textarea");
          ta.value = text;
          ta.style.position = "fixed"; ta.style.opacity = "0";
          document.body.appendChild(ta);
          ta.select();
          try { document.execCommand("copy"); } catch (_) {}
          document.body.removeChild(ta);
          const code = pre.querySelector("code") ?? pre;
          flashCopied(code);
        }
      });
    });
  })();
</script>
