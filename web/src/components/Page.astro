---
// All page sections wrapped into one component.
// The dict is passed in by the per-locale page entry; nothing here knows
// what the active language is, it just looks keys up in the dict.

import { formatCount, type Stats } from "../lib/stats";

interface Props {
  dict: Record<string, string>;
  pathPrefix: string;
  stats: Stats;
}

const { dict, pathPrefix, stats } = Astro.props as Props;
const t = (k: string) => dict[k] ?? k;

// FAQ entries — shape matches the keys inside the locale JSON.
const faq = [
  { q: "faq.what.q",     a: "faq.what.a" },
  { q: "faq.mcp.q",      a: "faq.mcp.a" },
  { q: "faq.multi.q",    a: "faq.multi.a" },
  { q: "faq.warp.q",     a: "faq.warp.a" },
  { q: "faq.privacy.q",  a: "faq.privacy.a" },
  { q: "faq.script.q",   a: "faq.script.a" },
  { q: "faq.platform.q", a: "faq.platform.a" },
  { q: "faq.opensrc.q",  a: "faq.opensrc.a" },
  { q: "faq.contrib.q",  a: "faq.contrib.a" },
];

// Personas section — three columns, each with header + body + 4 bullets.
// The bullet keys follow the persona prefix so locale files can stay flat.
const personas = [
  {
    icon: "🤖",
    title: "persona.ai.title",
    body: "persona.ai.body",
    bullets: ["persona.ai.bullets.1", "persona.ai.bullets.2", "persona.ai.bullets.3", "persona.ai.bullets.4"],
  },
  {
    icon: "⚙️",
    title: "persona.ops.title",
    body: "persona.ops.body",
    bullets: ["persona.ops.bullets.1", "persona.ops.bullets.2", "persona.ops.bullets.3", "persona.ops.bullets.4"],
  },
  {
    icon: "🔧",
    title: "persona.power.title",
    body: "persona.power.body",
    bullets: ["persona.power.bullets.1", "persona.power.bullets.2", "persona.power.bullets.3", "persona.power.bullets.4"],
  },
];

// What's-new-in-v0.12 section: four highlight cards. Same card shape as
// features but with a "v0.12" version chip and a denser tech-paragraph
// body (these are about what changed, not what exists).
const whatsnew = [
  { v: "v0.12", title: "whatsnew.flash.title",     body: "whatsnew.flash.body" },
  { v: "v0.9",  title: "whatsnew.instances.title", body: "whatsnew.instances.body" },
  { v: "v0.7",  title: "whatsnew.utf8.title",      body: "whatsnew.utf8.body" },
  { v: "v0.9",  title: "whatsnew.cwd.title",       body: "whatsnew.cwd.body" },
];

const principles = [
  { n: "01", title: "principles.local.title",       body: "principles.local.body" },
  { n: "02", title: "principles.outside.title",     body: "principles.outside.body" },
  { n: "03", title: "principles.mcp.title",         body: "principles.mcp.body" },
  { n: "04", title: "principles.parity.title",      body: "principles.parity.body" },
  { n: "05", title: "principles.subtraction.title", body: "principles.subtraction.body", wide: true },
];

const features = [
  { icon: "🔌", title: "features.mcp.title",    body: "features.mcp.body" },
  { icon: "⚡", title: "features.cli.title",    body: "features.cli.body" },
  { icon: "🖥️", title: "features.web.title",    body: "features.web.body" },
  { icon: "🌍", title: "features.i18n.title",   body: "features.i18n.body" },
  { icon: "🎬", title: "features.rec.title",    body: "features.rec.body" },
  { icon: "📸", title: "features.shot.title",   body: "features.shot.body" },
  { icon: "🌐", title: "features.proxy.title",  body: "features.proxy.body" },
  { icon: "⚙️", title: "features.engine.title", body: "features.engine.body" },
];

const cmpRows = [
  { row: "cmp.r.mcp",   unterm: "✓",         warp: "✗",      iterm: "✗",       ghostty: "✗" },
  { row: "cmp.r.local", unterm: "✓",         warp: "✗",      iterm: "✓",       ghostty: "✓" },
  { row: "cmp.r.gpu",   unterm: "✓",         warp: "✓",      iterm: "✗",       ghostty: "✓" },
  { row: "cmp.r.cross", unterm: "✓",         warp: "✓",      iterm: "macOS",   ghostty: "macOS+Linux" },
  { row: "cmp.r.oss",   unterm: "✓ MIT",     warp: "AGPL",   iterm: "✓ GPL",   ghostty: "✓ MIT" },
  { row: "cmp.r.ai",    unterm: "cmp.intentional", warp: "✓ (cloud)", iterm: "✗", ghostty: "✗" },
  { row: "cmp.r.i18n",  unterm: "✓",         warp: "en",     iterm: "en",      ghostty: "en" },
];

const dlBaseUrl = "https://github.com/unzooai/unterm/releases";
const releaseTag = "v0.12.2";

// Download links use the version pinned for this site build, not
// `stats.release`. The stats call can legitimately see the previous GitHub
// latest release if Cloudflare builds immediately after a version-bump push
// but before the release assets finish uploading.
//
// MSI and Windows-zip naming has historical quirks:
//   - DMG, deb, AppImage, win.zip: use the tag verbatim
//     (Unterm-macos-v0.12.2.dmg, unterm-v0.12.2.deb, Unterm-v0.12.2-x86_64.AppImage, Unterm-windows-v0.12.2.zip)
//   - MSI:  uses 3-segment SemVer with no `v` prefix
//     (Unterm-0.12.2-x64.msi) because WiX requires SemVer in
//     installer/Unterm.wxs and our build script reads from there.
//
// `releaseSemver` strips the `v` and pads to 3-segment so the MSI URL
// keeps building correctly. Example transforms:
//   "v0.12"   → "0.12.0"
//   "v0.12.5" → "0.12.5"
//   "0.13.0"  → "0.13.0"
const releaseSemver = (() => {
  const r = releaseTag.replace(/^v/, "");
  return r.split(".").length === 2 ? `${r}.0` : r;
})();

const dmgUrl      = `${dlBaseUrl}/latest/download/Unterm-macos-${releaseTag}.dmg`;
const debUrl      = `${dlBaseUrl}/latest/download/unterm-${releaseTag}.deb`;
const appimageUrl = `${dlBaseUrl}/latest/download/Unterm-${releaseTag}-x86_64.AppImage`;
const msiUrl      = `${dlBaseUrl}/latest/download/Unterm-${releaseSemver}-x64.msi`;
const winZipUrl   = `${dlBaseUrl}/latest/download/Unterm-windows-${releaseTag}.zip`;
const heroDownloads = [
  {
    href: dmgUrl,
    icon: "🍎",
    size: "install.macos.size",
    title: "install.macos.title",
    detail: "install.macos.detail",
    action: "install.macos.action",
  },
  {
    href: debUrl,
    icon: "🐧",
    size: "install.linux.size",
    title: "install.linux.title",
    detail: "install.linux.detail",
    action: "install.linux.action",
  },
  {
    href: msiUrl,
    icon: "🪟",
    size: "install.windows.size",
    title: "install.windows.title",
    detail: "install.windows.detail",
    action: "install.windows.action",
  },
];
---

<!-- ============== HERO ============== -->
<!-- Two-column on desktop, stacked on mobile. Left: product claim,
     download rail, and primary CTAs. Right: a CSS-rendered terminal
     scene showing an agent controlling the app through MCP. -->
<section class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-emerald-950/35 via-zinc-950 to-zinc-950"></div>
  <div class="absolute inset-0 opacity-[0.04]"
       style="background-image: radial-gradient(rgb(160 240 200) 1px, transparent 1px); background-size: 28px 28px;"></div>
  <div class="absolute pointer-events-none -top-40 left-1/2 -translate-x-1/2 w-[900px] h-[900px] rounded-full"
       style="background: radial-gradient(closest-side, rgb(16 185 129 / 0.18), transparent 70%);"></div>

  <div class="relative max-w-6xl mx-auto px-6 pt-20 pb-24">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-zinc-900/80 border border-zinc-800 text-xs text-zinc-400 mb-6">
          <span class="relative flex w-1.5 h-1.5">
            <span class="absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75 animate-ping"></span>
            <span class="relative inline-flex w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
          </span>
          <span>{t("hero.badge")}</span>
        </div>
        <h1 class="text-5xl sm:text-6xl lg:text-6xl xl:text-7xl font-bold tracking-tight text-zinc-50 leading-[1.02]">
          <span>{t("hero.title.1")}</span><br/>
          <span class="bg-gradient-to-r from-emerald-300 via-teal-300 to-cyan-300 bg-clip-text text-transparent">{t("hero.title.2")}</span>
        </h1>
        <p class="mt-6 text-lg text-zinc-400 max-w-xl mx-auto lg:mx-0 leading-relaxed">{t("hero.subtitle")}</p>
        <div class="mt-8 flex flex-wrap items-center justify-center lg:justify-start gap-3">
          <a id="smart-download"
             href={dmgUrl}
             data-macos={dmgUrl}
             data-linux={appimageUrl}
             data-windows={msiUrl}
             data-fallback={dmgUrl}
             data-fallback-label={t("hero.cta.download_fallback")}
             class="inline-flex items-center gap-2 px-5 py-3 rounded-lg bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-semibold transition shadow-lg shadow-emerald-500/20 hover:shadow-emerald-400/30">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 4v12m0 0l-4-4m4 4l4-4M5 20h14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
            <span>{t("hero.cta.download")}</span>
          </a>
          <a href={dlBaseUrl + "/latest"}
             class="inline-flex items-center gap-2 px-5 py-3 rounded-lg bg-zinc-900 hover:bg-zinc-800 border border-zinc-800 hover:border-zinc-700 text-zinc-100 font-medium transition">
            <span>{t("hero.cta.other")}</span>
          </a>
          <a href="https://github.com/unzooai/unterm" target="_blank" rel="noopener"
             class="inline-flex items-center gap-2 px-5 py-3 rounded-lg bg-zinc-900 hover:bg-zinc-800 border border-zinc-800 hover:border-zinc-700 text-zinc-100 font-medium transition">
            <span>{t("hero.cta.github")}</span>
          </a>
        </div>
        <div class="mt-6 flex flex-wrap items-center justify-center lg:justify-start gap-2 text-xs">
          <a href="https://github.com/unzooai/unterm/stargazers" target="_blank" rel="noopener"
             class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-zinc-900/80 hover:bg-zinc-800 border border-zinc-800 text-zinc-300 transition">
            <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            <span class="font-semibold" data-stat="stars">{formatCount(stats.stars)}</span>
            <span class="text-zinc-500">stars</span>
          </a>
          <a href="https://github.com/unzooai/unterm/releases" target="_blank" rel="noopener"
             class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-zinc-900/80 hover:bg-zinc-800 border border-zinc-800 text-zinc-300 transition">
            <svg class="w-3.5 h-3.5 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2.4" viewBox="0 0 24 24"><path d="M12 4v12m0 0l-4-4m4 4l4-4M5 20h14"/></svg>
            <span class="font-semibold" data-stat="downloads">{formatCount(stats.downloads)}</span>
            <span class="text-zinc-500">downloads</span>
          </a>
        </div>
        <p class="mt-6 text-xs text-zinc-500">{t("hero.meta")}</p>

        <div class="mt-8 grid sm:grid-cols-3 gap-3">
          {heroDownloads.map((d) => (
            <a href={d.href}
               class="group flex flex-col gap-3 bg-zinc-900/70 hover:bg-zinc-900 border border-zinc-800 hover:border-zinc-700 rounded-xl p-4 text-left transition">
              <div class="flex items-center justify-between">
                <div class="text-2xl">{d.icon}</div>
                <span class="text-[11px] font-mono text-zinc-500">{t(d.size)}</span>
              </div>
              <div class="font-semibold text-zinc-100">{t(d.title)}</div>
              <div class="text-sm text-zinc-400 leading-relaxed">{t(d.detail)}</div>
              <div class="text-xs text-emerald-400 group-hover:text-emerald-300 font-mono">{t(d.action)}</div>
            </a>
          ))}
        </div>
      </div>

      <div class="relative">
        <div class="absolute -inset-4 bg-gradient-to-r from-emerald-500/20 via-teal-500/10 to-cyan-500/20 blur-2xl rounded-2xl"></div>
        <div class="relative rounded-xl overflow-hidden border border-zinc-800 shadow-2xl shadow-black/60 bg-zinc-950">
          <div class="flex items-center gap-2 px-4 py-2.5 bg-zinc-900/80 border-b border-zinc-800">
            <div class="flex gap-1.5">
              <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
              <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
            </div>
            <div class="flex-1 text-center text-xs font-mono text-zinc-400">Unterm — <span class="text-emerald-400">alpha</span> — /work/auth-service</div>
            <span class="text-xs font-mono text-zinc-600">MCP on</span>
          </div>
          <div class="flex items-center gap-1 px-2 py-1.5 bg-zinc-900/40 border-b border-zinc-800/60 text-xs font-mono">
            <div class="flex items-center gap-1.5 px-2.5 py-1 rounded bg-zinc-800/60 text-zinc-200">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
              <span>claude code</span>
            </div>
            <div class="flex items-center gap-1.5 px-2.5 py-1 text-zinc-500 hover:text-zinc-300">
              <span>build</span>
            </div>
            <div class="flex items-center gap-1.5 px-2.5 py-1 text-zinc-500 hover:text-zinc-300">
              <span>logs</span>
            </div>
            <div class="ml-auto text-zinc-600">agent-ready</div>
          </div>
          <div class="px-4 py-4 font-mono text-[12.5px] leading-relaxed bg-zinc-950 min-h-[300px] space-y-1.5">
            <div class="text-zinc-500"><span class="text-emerald-400">→</span> claude: open /work/auth-service and switch cwd</div>
            <div class="text-zinc-300"><span class="text-cyan-400">unterm</span> mcp.pane.set_cwd <span class="text-zinc-500">{`{ pane_id: 7, cwd: "/work/auth-service" }`}</span></div>
            <div class="text-zinc-500">     → <span class="text-emerald-400">{`{ ok: true }`}</span></div>
            <div class="text-zinc-300"><span class="text-cyan-400">unterm</span> mcp.exec.run <span class="text-zinc-500">{`{ pane_id: 7, cmd: "cargo test" }`}</span></div>
            <div class="text-zinc-500">     <span class="text-zinc-400">running 142 tests</span></div>
            <div class="text-zinc-500">     <span class="text-emerald-400">test result: ok. 142 passed; 0 failed</span></div>
            <div class="text-zinc-300"><span class="text-cyan-400">unterm</span> mcp.screen.read <span class="text-zinc-500">{`{ pane_id: 7, lines: 5 }`}</span></div>
            <div class="text-zinc-500">     → <span class="text-zinc-300">"cwd switched, build is green"</span></div>
            <div class="text-zinc-500"><span class="text-emerald-400">←</span> claude: commit and open the release branch.</div>
            <div class="flex items-center gap-1 mt-2">
              <span class="text-emerald-400">$</span>
              <span class="inline-block w-2 h-4 bg-emerald-400 animate-pulse"></span>
            </div>
          </div>
          <div class="flex items-center text-[11px] font-mono text-zinc-400 bg-zinc-900/60 border-t border-zinc-800 px-3 py-1.5 gap-2 overflow-hidden">
            <span>pwsh 7</span>
            <span class="text-zinc-700">|</span>
            <span class="text-emerald-400">~/work/auth-service</span>
            <span class="text-zinc-700">|</span>
            <span>120×32</span>
            <span class="text-zinc-700">|</span>
            <span>📁 auth-service</span>
            <span class="text-zinc-700 hidden sm:inline">|</span>
            <span class="hidden sm:inline">🌐 proxy:on</span>
            <span class="text-zinc-700 hidden md:inline">|</span>
            <span class="hidden md:inline">🌙 midnight</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============== TAGLINE ============== -->
<section class="py-20 border-t border-zinc-900">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight text-zinc-100 leading-tight">{t("tagline.title")}</h2>
    <p class="mt-6 text-lg text-zinc-400 leading-relaxed" set:html={t("tagline.body")}></p>
  </div>
</section>

<!-- ============== PERSONAS ============== -->
<!-- Three persona cards in a single grid. Each card mirrors the
     "header + 50-80 word body + 4 bullets" shape SoloMD uses for its
     Writers / Researchers / Developers section, adapted to our
     audience: AI engineers, DevOps, OSS hackers. -->
<section class="py-20 border-t border-zinc-900 bg-zinc-950">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-3xl font-semibold tracking-tight text-center">{t("persona.title")}</h2>
    <p class="mt-3 text-center text-zinc-400 max-w-2xl mx-auto">{t("persona.subtitle")}</p>
    <div class="mt-12 grid md:grid-cols-3 gap-5">
      {personas.map((p) => (
        <div class="bg-zinc-900/40 border border-zinc-800 rounded-xl p-6 flex flex-col">
          <div class="text-3xl">{p.icon}</div>
          <div class="mt-3 text-lg font-semibold text-zinc-100">{t(p.title)}</div>
          <p class="mt-2 text-sm text-zinc-400 leading-relaxed" set:html={t(p.body)}></p>
          <ul class="mt-4 space-y-1.5 text-sm text-zinc-300">
            {p.bullets.map((b) => (
              <li class="flex items-start gap-2">
                <span class="mt-1 w-1 h-1 rounded-full bg-emerald-400 shrink-0"></span>
                <span>{t(b)}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============== INSTALL ============== -->
<section id="install" class="py-20 border-t border-zinc-900">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="text-3xl font-semibold tracking-tight text-center">{t("install.title")}</h2>
    <p class="mt-3 text-center text-zinc-400">{t("install.subtitle")}</p>

    <!-- One-shot installer commands. Tabs are pure CSS (radio + :checked
         siblings) so JavaScript is optional — copy still works without JS. -->
    <div class="mt-10 rounded-xl border border-zinc-800 bg-zinc-900/40 overflow-hidden">
      <div class="flex border-b border-zinc-800 text-sm font-medium">
        <button type="button" data-tab="unix"
          class="install-tab px-5 py-3 text-zinc-100 bg-zinc-800/60 border-r border-zinc-800">
          🍎 macOS · 🐧 Linux
        </button>
        <button type="button" data-tab="win"
          class="install-tab px-5 py-3 text-zinc-400 hover:text-zinc-100">
          🪟 Windows
        </button>
        <div class="ml-auto text-xs text-zinc-500 self-center pr-4 hidden sm:block">{t("install.copy_hint")}</div>
      </div>

      <div class="install-pane" data-pane="unix">
        <pre class="font-mono text-sm text-zinc-200 px-5 py-5 overflow-x-auto"><code>curl -fsSL https://unterm.app/install.sh | sh</code></pre>
        <p class="text-xs text-zinc-500 px-5 pb-4" set:html={t("install.unix_detail")}></p>
      </div>
      <div class="install-pane hidden" data-pane="win">
        <pre class="font-mono text-sm text-zinc-200 px-5 py-5 overflow-x-auto"><code>irm https://unterm.app/install.ps1 | iex</code></pre>
        <p class="text-xs text-zinc-500 px-5 pb-4" set:html={t("install.win_detail")}></p>
      </div>
    </div>

    <p class="mt-6 text-center text-xs text-zinc-500">{t("install.or_manual")}</p>

    <!-- Platform cards. macOS has one artifact (DMG) so the whole card
         is one link. Linux + Windows ship two artifacts each (deb +
         AppImage / MSI + portable .zip) so we expose both as direct
         action chips inside the card — the user shouldn't have to
         click through to the GitHub releases page to pick. The card
         itself is no longer wrapped in <a>; only the chips are
         clickable, with hover/border states on the card for the
         "this is one platform" affordance. -->
    <div class="mt-4 grid sm:grid-cols-3 gap-4">
      <!-- macOS — single artifact -->
      <a href={dmgUrl}
         class="group block bg-zinc-900/60 hover:bg-zinc-900 border border-zinc-800 hover:border-zinc-700 rounded-xl p-5 transition">
        <div class="flex items-center justify-between">
          <div class="text-3xl">🍎</div>
          <span class="text-xs font-mono text-zinc-500">{t("install.macos.size")}</span>
        </div>
        <div class="mt-3 font-semibold">{t("install.macos.title")}</div>
        <div class="text-sm text-zinc-400 mt-1">{t("install.macos.detail")}</div>
        <div class="mt-3 text-xs text-emerald-400 group-hover:text-emerald-300">{t("install.macos.action")}</div>
      </a>

      <!-- Linux — two artifacts: .deb + AppImage -->
      <div class="bg-zinc-900/60 hover:bg-zinc-900 border border-zinc-800 hover:border-zinc-700 rounded-xl p-5 transition flex flex-col">
        <div class="flex items-center justify-between">
          <div class="text-3xl">🐧</div>
          <span class="text-xs font-mono text-zinc-500">{t("install.linux.size")}</span>
        </div>
        <div class="mt-3 font-semibold">{t("install.linux.title")}</div>
        <div class="text-sm text-zinc-400 mt-1 flex-1">{t("install.linux.detail")}</div>
        <div class="mt-3 flex flex-wrap gap-2">
          <a href={debUrl}
             class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-mono bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-300 hover:text-emerald-200 border border-emerald-500/20 hover:border-emerald-500/40 transition">
            .deb →
          </a>
          <a href={appimageUrl}
