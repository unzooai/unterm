---
// All page sections wrapped into one component.
// The dict is passed in by the per-locale page entry; nothing here knows
// what the active language is, it just looks keys up in the dict.

import { formatCount, type Stats } from "../lib/stats";

interface Props {
  dict: Record<string, string>;
  pathPrefix: string;
  stats: Stats;
}

const { dict, pathPrefix, stats } = Astro.props as Props;
const t = (k: string) => dict[k] ?? k;

// FAQ entries — shape matches the keys inside the locale JSON.
const faq = [
  { q: "faq.what.q",    a: "faq.what.a" },
  { q: "faq.mcp.q",     a: "faq.mcp.a" },
  { q: "faq.warp.q",    a: "faq.warp.a" },
  { q: "faq.privacy.q", a: "faq.privacy.a" },
  { q: "faq.script.q",  a: "faq.script.a" },
  { q: "faq.opensrc.q", a: "faq.opensrc.a" },
];

const principles = [
  { n: "01", title: "principles.local.title",       body: "principles.local.body" },
  { n: "02", title: "principles.outside.title",     body: "principles.outside.body" },
  { n: "03", title: "principles.mcp.title",         body: "principles.mcp.body" },
  { n: "04", title: "principles.parity.title",      body: "principles.parity.body" },
  { n: "05", title: "principles.subtraction.title", body: "principles.subtraction.body", wide: true },
];

const features = [
  { icon: "🔌", title: "features.mcp.title",    body: "features.mcp.body" },
  { icon: "⚡", title: "features.cli.title",    body: "features.cli.body" },
  { icon: "🖥️", title: "features.web.title",    body: "features.web.body" },
  { icon: "🌍", title: "features.i18n.title",   body: "features.i18n.body" },
  { icon: "🎬", title: "features.rec.title",    body: "features.rec.body" },
  { icon: "📸", title: "features.shot.title",   body: "features.shot.body" },
  { icon: "🌐", title: "features.proxy.title",  body: "features.proxy.body" },
  { icon: "⚙️", title: "features.engine.title", body: "features.engine.body" },
];

const cmpRows = [
  { row: "cmp.r.mcp",   unterm: "✓",         warp: "✗",      iterm: "✗",       ghostty: "✗" },
  { row: "cmp.r.local", unterm: "✓",         warp: "✗",      iterm: "✓",       ghostty: "✓" },
  { row: "cmp.r.gpu",   unterm: "✓",         warp: "✓",      iterm: "✗",       ghostty: "✓" },
  { row: "cmp.r.cross", unterm: "✓",         warp: "✓",      iterm: "macOS",   ghostty: "macOS+Linux" },
  { row: "cmp.r.oss",   unterm: "✓ MIT",     warp: "AGPL",   iterm: "✓ GPL",   ghostty: "✓ MIT" },
  { row: "cmp.r.ai",    unterm: "cmp.intentional", warp: "✓ (cloud)", iterm: "✗", ghostty: "✗" },
  { row: "cmp.r.i18n",  unterm: "✓",         warp: "en",     iterm: "en",      ghostty: "en" },
];

const dlBaseUrl = "https://github.com/unzooai/unterm/releases";
// `stats.release` is the latest tag returned by the GitHub API at build
// time. Driving the DMG URL off it means we don't have to hand-edit this
// file every time we cut a new tag — the next deploy auto-points at it.
const dmgUrl = `${dlBaseUrl}/latest/download/Unterm-macos-${stats.release}.dmg`;
---

<!-- ============== HERO ============== -->
<section class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-emerald-950/30 via-zinc-950 to-zinc-950"></div>
  <div class="relative max-w-6xl mx-auto px-6 pt-24 pb-20 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-zinc-900/80 border border-zinc-800 text-xs text-zinc-400 mb-6">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
      <span>{t("hero.badge")}</span>
    </div>
    <h1 class="text-5xl sm:text-6xl md:text-7xl font-bold tracking-tight text-zinc-50 leading-[1.05]">
      <span>{t("hero.title.1")}</span><br/>
      <span class="bg-gradient-to-r from-emerald-300 via-teal-300 to-cyan-300 bg-clip-text text-transparent">{t("hero.title.2")}</span>
    </h1>
    <p class="mt-6 text-lg sm:text-xl text-zinc-400 max-w-2xl mx-auto">{t("hero.subtitle")}</p>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      <a href={dmgUrl}
         class="inline-flex items-center gap-2 px-5 py-3 rounded-lg bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-semibold transition">
        <span>{t("hero.cta.download")}</span>
      </a>
      <a href={dlBaseUrl + "/latest"}
         class="inline-flex items-center gap-2 px-5 py-3 rounded-lg bg-zinc-900 hover:bg-zinc-800 border border-zinc-800 text-zinc-100 font-medium transition">
        <span>{t("hero.cta.other")}</span>
      </a>
      <a href="https://github.com/unzooai/unterm" target="_blank" rel="noopener"
         class="inline-flex items-center gap-2 px-5 py-3 rounded-lg bg-zinc-900 hover:bg-zinc-800 border border-zinc-800 text-zinc-100 font-medium transition">
        <span>{t("hero.cta.github")}</span>
      </a>
    </div>
    <!-- Social proof chips. SSR text is the build-time number from
         lib/stats.ts; the data-stat markers let our tiny inline script
         live-refresh from /api/stats once the page is interactive, so
         visitors see today's count even if the last deploy was last week.
         Numbers can be null on either side (build failed / API failed) —
         formatCount renders an em dash in that case. -->
    <div class="mt-6 flex flex-wrap items-center justify-center gap-2 text-xs">
      <a href="https://github.com/unzooai/unterm/stargazers" target="_blank" rel="noopener"
         class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-zinc-900/80 hover:bg-zinc-800 border border-zinc-800 text-zinc-300 transition">
        <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
        <span class="font-semibold" data-stat="stars">{formatCount(stats.stars)}</span>
        <span class="text-zinc-500">stars</span>
      </a>
      <a href="https://github.com/unzooai/unterm/releases" target="_blank" rel="noopener"
         class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-zinc-900/80 hover:bg-zinc-800 border border-zinc-800 text-zinc-300 transition">
        <svg class="w-3.5 h-3.5 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2.4" viewBox="0 0 24 24"><path d="M12 4v12m0 0l-4-4m4 4l4-4M5 20h14"/></svg>
        <span class="font-semibold" data-stat="downloads">{formatCount(stats.downloads)}</span>
        <span class="text-zinc-500">downloads</span>
      </a>
    </div>
    <p class="mt-6 text-xs text-zinc-500">{t("hero.meta")}</p>
  </div>
</section>

<!-- ============== INSTALL ============== -->
<section id="install" class="py-20 border-t border-zinc-900">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="text-3xl font-semibold tracking-tight text-center">{t("install.title")}</h2>
    <p class="mt-3 text-center text-zinc-400">{t("install.subtitle")}</p>

    <!-- One-shot installer commands. Tabs are pure CSS (radio + :checked
         siblings) so JavaScript is optional — copy still works without JS. -->
    <div class="mt-10 rounded-xl border border-zinc-800 bg-zinc-900/40 overflow-hidden">
      <div class="flex border-b border-zinc-800 text-sm font-medium">
        <button type="button" data-tab="unix"
          class="install-tab px-5 py-3 text-zinc-100 bg-zinc-800/60 border-r border-zinc-800">
          🍎 macOS · 🐧 Linux
        </button>
        <button type="button" data-tab="win"
          class="install-tab px-5 py-3 text-zinc-400 hover:text-zinc-100">
          🪟 Windows
        </button>
        <div class="ml-auto text-xs text-zinc-500 self-center pr-4 hidden sm:block">{t("install.copy_hint")}</div>
      </div>

      <div class="install-pane" data-pane="unix">
        <pre class="font-mono text-sm text-zinc-200 px-5 py-5 overflow-x-auto"><code>curl -fsSL https://unterm.app/install.sh | sh</code></pre>
        <p class="text-xs text-zinc-500 px-5 pb-4" set:html={t("install.unix_detail")}></p>
      </div>
      <div class="install-pane hidden" data-pane="win">
        <pre class="font-mono text-sm text-zinc-200 px-5 py-5 overflow-x-auto"><code>irm https://unterm.app/install.ps1 | iex</code></pre>
        <p class="text-xs text-zinc-500 px-5 pb-4" set:html={t("install.win_detail")}></p>
      </div>
    </div>

    <p class="mt-6 text-center text-xs text-zinc-500">{t("install.or_manual")}</p>

    <div class="mt-4 grid sm:grid-cols-3 gap-4">
      <a href={dmgUrl}
         class="group block bg-zinc-900/60 hover:bg-zinc-900 border border-zinc-800 rounded-xl p-5 transition">
        <div class="text-3xl">🍎</div>
        <div class="mt-3 font-semibold">{t("install.macos.title")}</div>
        <div class="text-sm text-zinc-400 mt-1">{t("install.macos.detail")}</div>
        <div class="mt-3 text-xs text-emerald-400 group-hover:text-emerald-300">{t("install.macos.action")}</div>
      </a>
      <a href={dlBaseUrl + "/latest"}
         class="group block bg-zinc-900/60 hover:bg-zinc-900 border border-zinc-800 rounded-xl p-5 transition">
        <div class="text-3xl">🐧</div>
        <div class="mt-3 font-semibold">{t("install.linux.title")}</div>
        <div class="text-sm text-zinc-400 mt-1">{t("install.linux.detail")}</div>
        <div class="mt-3 text-xs text-emerald-400 group-hover:text-emerald-300">{t("install.linux.action")}</div>
      </a>
      <a href={dlBaseUrl + "/latest"}
         class="group block bg-zinc-900/60 hover:bg-zinc-900 border border-zinc-800 rounded-xl p-5 transition">
        <div class="text-3xl">🪟</div>
        <div class="mt-3 font-semibold">{t("install.windows.title")}</div>
        <div class="text-sm text-zinc-400 mt-1">{t("install.windows.detail")}</div>
        <div class="mt-3 text-xs text-emerald-400 group-hover:text-emerald-300">{t("install.windows.action")}</div>
      </a>
    </div>
  </div>
</section>

<!-- ============== FEATURES ============== -->
<section id="features" class="py-20 border-t border-zinc-900">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-3xl font-semibold tracking-tight text-center">{t("features.title")}</h2>
    <p class="mt-3 text-center text-zinc-400 max-w-2xl mx-auto">{t("features.subtitle")}</p>
    <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-4 gap-4">
      {features.map((f) => (
        <div class="bg-zinc-900/60 border border-zinc-800 rounded-xl p-5">
          <div class="text-2xl">{f.icon}</div>
          <div class="mt-3 font-semibold">{t(f.title)}</div>
          <p class="mt-2 text-sm text-zinc-400" set:html={t(f.body)}></p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============== PRINCIPLES ============== -->
<section class="py-20 border-t border-zinc-900 bg-zinc-950">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-semibold tracking-tight text-center">{t("principles.title")}</h2>
    <div class="mt-12 grid md:grid-cols-2 gap-4">
      {principles.map((p) => (
        <div class={"bg-zinc-900/40 border border-zinc-800 rounded-xl p-6" + (p.wide ? " md:col-span-2" : "")}>
          <div class="text-emerald-400 font-mono text-xs">{p.n}</div>
          <div class="mt-2 font-semibold">{t(p.title)}</div>
          <p class="mt-2 text-sm text-zinc-400">{t(p.body)}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============== COMPARISON ============== -->
<section class="py-20 border-t border-zinc-900">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-semibold tracking-tight text-center">{t("cmp.title")}</h2>
    <p class="mt-3 text-center text-zinc-400 max-w-2xl mx-auto">{t("cmp.subtitle")}</p>
    <div class="mt-10 overflow-x-auto rounded-xl border border-zinc-800">
      <table class="w-full text-sm">
        <thead class="bg-zinc-900/80 text-zinc-400">
          <tr>
            <th class="text-left px-4 py-3 font-medium">{t("cmp.h.feature")}</th>
            <th class="px-4 py-3 font-medium text-emerald-400">Unterm</th>
            <th class="px-4 py-3 font-medium">Warp</th>
            <th class="px-4 py-3 font-medium">iTerm2</th>
            <th class="px-4 py-3 font-medium">Ghostty</th>
          </tr>
        </thead>
        <tbody class="text-zinc-200">
          {cmpRows.map((r) => (
            <tr class="border-t border-zinc-800">
              <td class="px-4 py-3">{t(r.row)}</td>
              <td class="text-center text-emerald-400">{t(r.unterm)}</td>
              <td class="text-center text-zinc-400">{r.warp}</td>
              <td class="text-center text-zinc-400">{r.iterm}</td>
              <td class="text-center text-zinc-400">{r.ghostty}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="mt-4 text-xs text-zinc-500 text-center">{t("cmp.note")}</p>
  </div>
</section>

<!-- ============== DOWNLOAD ============== -->
<section id="download" class="py-20 border-t border-zinc-900 bg-gradient-to-b from-zinc-950 via-emerald-950/10 to-zinc-950">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-3xl font-semibold tracking-tight">{t("dl.title")}</h2>
    <p class="mt-3 text-zinc-400">{t("dl.subtitle")}</p>
    <a href="https://github.com/unzooai/unterm/releases/tag/v0.9.0"
       class="mt-8 inline-flex items-center gap-2 px-5 py-3 rounded-lg bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-semibold transition">
      <span>{t("dl.cta")}</span>
    </a>
  </div>
</section>

<!-- ============== FAQ ============== -->
<section id="faq" class="py-20 border-t border-zinc-900">
  <div class="max-w-3xl mx-auto px-6">
    <h2 class="text-3xl font-semibold tracking-tight text-center">{t("faq.title")}</h2>
    <div class="mt-10 divide-y divide-zinc-800 border border-zinc-800 rounded-xl bg-zinc-900/40">
      {faq.map((q) => (
        <details class="group">
          <summary class="cursor-pointer flex items-center justify-between px-5 py-4 hover:bg-zinc-900 select-none">
            <span class="font-medium pr-4">{t(q.q)}</span>
            <svg class="w-4 h-4 shrink-0 text-zinc-500 group-open:rotate-180 transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <p class="px-5 pb-5 text-sm text-zinc-400 leading-relaxed" set:html={t(q.a)}></p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- ============== SISTER PROJECTS ============== -->
<section class="py-20 border-t border-zinc-900">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-semibold tracking-tight text-center">{t("sister.title")}</h2>
    <p class="mt-3 text-center text-zinc-400 max-w-2xl mx-auto">{t("sister.subtitle")}</p>
    <div class="mt-10 grid md:grid-cols-2 gap-4">
      <a href="https://solomd.app" target="_blank" rel="noopener"
         class="group block bg-zinc-900/60 hover:bg-zinc-900 border border-zinc-800 hover:border-zinc-700 rounded-xl p-6 transition">
        <div class="flex items-center justify-between">
          <div class="text-xl font-semibold">SoloMD</div>
          <svg class="w-4 h-4 text-zinc-500 group-hover:text-zinc-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg>
        </div>
        <p class="mt-2 text-sm text-zinc-400">{t("sister.solomd")}</p>
      </a>
      <a href="https://unflick.app" target="_blank" rel="noopener"
         class="group block bg-zinc-900/60 hover:bg-zinc-900 border border-zinc-800 hover:border-zinc-700 rounded-xl p-6 transition">
        <div class="flex items-center justify-between">
          <div class="text-xl font-semibold">Unflick</div>
          <svg class="w-4 h-4 text-zinc-500 group-hover:text-zinc-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg>
        </div>
        <p class="mt-2 text-sm text-zinc-400">{t("sister.unflick")}</p>
      </a>
    </div>
  </div>
</section>

<script is:inline>
  // Install section: tab toggle + click-to-copy.
  //
  // is:inline so the markup ships even when JavaScript is disabled — the
  // first tab's <pre> is visible by default and users can still copy with
  // their own select/cmd+c. The script just upgrades the experience.
  (function () {
    const tabs = document.querySelectorAll(".install-tab");
    const panes = document.querySelectorAll(".install-pane");
    function activate(name) {
      tabs.forEach((t) => {
        const on = t.dataset.tab === name;
        t.classList.toggle("text-zinc-100", on);
        t.classList.toggle("bg-zinc-800/60", on);
        t.classList.toggle("text-zinc-400", !on);
      });
      panes.forEach((p) => {
        p.classList.toggle("hidden", p.dataset.pane !== name);
      });
    }
    tabs.forEach((t) => t.addEventListener("click", () => activate(t.dataset.tab)));

    // Click anywhere on the <pre> command block to copy. Keeps a tiny inline
    // toast so the user knows the copy fired without us having to render a
    // separate Copy button.
    const flashCopied = (el) => {
      const original = el.dataset.original ?? el.textContent;
      el.dataset.original = original;
      el.textContent = "✓ copied";
      setTimeout(() => { el.textContent = original; }, 1100);
    };
    document.querySelectorAll(".install-pane pre").forEach((pre) => {
      pre.style.cursor = "copy";
      pre.title = "click to copy";
      pre.addEventListener("click", async () => {
        const text = pre.textContent.trim();
        try {
          await navigator.clipboard.writeText(text);
          const code = pre.querySelector("code") ?? pre;
          flashCopied(code);
        } catch (_) {
          // navigator.clipboard requires HTTPS or localhost; fall back to
          // a hidden textarea + execCommand on legacy contexts.
          const ta = document.createElement("textarea");
          ta.value = text;
          ta.style.position = "fixed"; ta.style.opacity = "0";
          document.body.appendChild(ta);
          ta.select();
          try { document.execCommand("copy"); } catch (_) {}
          document.body.removeChild(ta);
          const code = pre.querySelector("code") ?? pre;
          flashCopied(code);
        }
      });
    });
  })();
</script>
