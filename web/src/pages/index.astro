---
import Base from "../layouts/Base.astro";
import Page from "../components/Page.astro";
import dict from "../i18n/en-US.json";
import { LOCALES, alternates } from "../i18n/locales";
import { fetchStats } from "../lib/stats";

const stats = await fetchStats();
---

<Base
  lang="en-US"
  dict={dict}
  alternates={alternates()}
  locales={LOCALES}
  pathPrefix=""
>
  <Page dict={dict} pathPrefix="" stats={stats} />
</Base>
