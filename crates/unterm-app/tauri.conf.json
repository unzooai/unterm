{
  "$schema": "https://raw.githubusercontent.com/nicbarker/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Unterm",
  "version": "0.1.0",
  "identifier": "com.unzoo.unterm",
  "build": {
    "beforeBuildCommand": "node unterm-app/build-frontend.js",
    "frontendDist": "./frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Unterm",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "resizable": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
